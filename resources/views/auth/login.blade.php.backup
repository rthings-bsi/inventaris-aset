<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Manajemen Aset</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --blue-900: #0b1e3b;
            --blue-800: #112a52;
            --blue-700: #1a3a6b;
            --blue-600: #1f4e8c;
            --blue-500: #2c6fbd;
            --blue-400: #5ea0f2;
            --blue-200: #d7e8ff;
            --slate-50: #f8fafc;
            --slate-100: #f1f5f9;
            --slate-700: #334155;
            --slate-900: #0f172a;
            --white: #ffffff;
            --purple-500: #6C3FF5;
            --purple-600: #5A32D1;
            --orange-400: #FF9B6B;
            --yellow-400: #E8D754;
            --black-800: #2D2D2D;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: "Plus Jakarta Sans", sans-serif;
            color: var(--slate-900);
            min-height: 100vh;
            background: linear-gradient(135deg, var(--blue-900) 0%, var(--blue-700) 40%, var(--blue-400) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            overflow: hidden;
        }

        .bg-shape {
            position: absolute;
            border-radius: 999px;
            filter: blur(0px);
            opacity: 0.45;
            animation: float 10s ease-in-out infinite;
        }

        .bg-shape.one {
            width: 420px;
            height: 420px;
            background: radial-gradient(circle at 30% 30%, #7fb7ff, #2a5aa2);
            top: -120px;
            right: -100px;
            animation-delay: 0s;
        }

        .bg-shape.two {
            width: 320px;
            height: 320px;
            background: radial-gradient(circle at 30% 30%, #9ec9ff, #1d4a8a);
            bottom: -140px;
            left: -90px;
            animation-delay: 2s;
        }

        .grid-pattern {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
            background-size: 38px 38px;
            opacity: 0.18;
            pointer-events: none;
        }

        .login-card {
            position: relative;
            width: min(1100px, 100%);
            background: linear-gradient(180deg, var(--white), var(--slate-50));
            border-radius: 22px;
            box-shadow: 0 24px 60px rgba(5, 18, 43, 0.35);
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            overflow: hidden;
            animation: fadeInUp 0.8s ease-out;
        }

        .login-visual {
            padding: 32px 28px;
            background: linear-gradient(135deg, var(--purple-500) 0%, #8A5CF5 100%);
            color: var(--white);
            display: flex;
            flex-direction: column;
            gap: 20px;
            position: relative;
            overflow: hidden;
            min-height: 600px;
        }

        /* Decorative elements */
        .visual-grid {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
            background-size: 20px 20px;
            pointer-events: none;
        }

        .visual-blur {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            pointer-events: none;
        }

        .visual-blur-1 {
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.1);
            top: -100px;
            right: -100px;
        }

        .visual-blur-2 {
            width: 400px;
            height: 400px;
            background: rgba(255, 255, 255, 0.05);
            bottom: -150px;
            left: -150px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 700;
            font-size: 20px;
            letter-spacing: 0.5px;
            position: relative;
            z-index: 2;
        }

        .brand-badge {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.16);
            backdrop-filter: blur(10px);
            display: grid;
            place-items: center;
            font-size: 22px;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .visual-title {
            font-size: 28px;
            font-weight: 600;
            line-height: 1.2;
            position: relative;
            z-index: 2;
        }

        .visual-subtitle {
            color: rgba(255, 255, 255, 0.8);
            font-size: 15px;
            line-height: 1.6;
            position: relative;
            z-index: 2;
        }

        /* Character Container */
        .characters-container {
            position: relative;
            flex: 1;
            min-height: 350px;
            margin-top: 10px;
            z-index: 2;
        }

        .character {
            position: absolute;
            bottom: 0;
            transition: all 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
            transform-origin: bottom center;
            cursor: pointer;
        }

        /* Purple character */
        .character-purple {
            left: 50px;
            width: 160px;
            height: 320px;
            background: var(--purple-500);
            border-radius: 16px 16px 0 0;
            z-index: 1;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }

        .character-purple.typing {
            height: 350px;
        }

        .character-purple.peeking {
            transform: translateX(20px) rotate(2deg);
        }

        .eyes-purple {
            position: absolute;
            display: flex;
            gap: 24px;
            transition: all 0.5s ease;
            top: 60px;
            left: 40px;
        }

        .eye {
            width: 24px;
            height: 24px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .eye.blinking {
            height: 4px;
            margin-top: 10px;
        }

        .pupil {
            width: 12px;
            height: 12px;
            background: var(--black-800);
            border-radius: 50%;
            transition: transform 0.1s ease-out;
        }

        /* Black character */
        .character-black {
            left: 200px;
            width: 100px;
            height: 280px;
            background: var(--black-800);
            border-radius: 12px 12px 0 0;
            z-index: 2;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
        }

        .character-black.looking {
            transform: skewX(5deg) translateX(15px);
        }

        .eyes-black {
            position: absolute;
            display: flex;
            gap: 20px;
            transition: all 0.5s ease;
            top: 45px;
            left: 20px;
        }

        .eye-black {
            width: 20px;
            height: 20px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .eye-black.blinking {
            height: 4px;
            margin-top: 8px;
        }

        .pupil-black {
            width: 10px;
            height: 10px;
            background: var(--black-800);
            border-radius: 50%;
            transition: transform 0.1s ease-out;
        }

        /* Orange character */
        .character-orange {
            left: 20px;
            width: 180px;
            height: 180px;
            background: var(--orange-400);
            border-radius: 90px 90px 0 0;
            z-index: 3;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
        }

        .eyes-orange {
            position: absolute;
            display: flex;
            gap: 24px;
            transition: all 0.5s ease;
            top: 70px;
            left: 50px;
        }

        .pupil-orange {
            width: 14px;
            height: 14px;
            background: var(--black-800);
            border-radius: 50%;
            transition: transform 0.1s ease-out;
        }

        /* Yellow character */
        .character-yellow {
            left: 250px;
            width: 120px;
            height: 220px;
            background: var(--yellow-400);
            border-radius: 60px 60px 0 0;
            z-index: 4;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
        }

        .eyes-yellow {
            position: absolute;
            display: flex;
            gap: 20px;
            transition: all 0.5s ease;
            top: 50px;
            left: 25px;
        }

        .pupil-yellow {
            width: 12px;
            height: 12px;
            background: var(--black-800);
            border-radius: 50%;
            transition: transform 0.1s ease-out;
        }

        .mouth-yellow {
            position: absolute;
            width: 60px;
            height: 4px;
            background: var(--black-800);
            border-radius: 2px;
            transition: all 0.5s ease;
            bottom: 60px;
            left: 30px;
        }

        /* Footer links */
        .visual-footer {
            position: relative;
            z-index: 2;
            display: flex;
            gap: 2rem;
            margin-top: 20px;
            font-size: 0.85rem;
        }

        .visual-footer a {
            color: rgba(255, 255, 255, 0.6);
            text-decoration: none;
            transition: color 0.2s ease;
        }

        .visual-footer a:hover {
            color: white;
        }

        /* Asset cards (tetap dipertahankan) */
        .asset-stack {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            position: relative;
            z-index: 2;
            margin-top: 20px;
        }

        .asset-card {
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 16px;
            padding: 16px;
        }

        .asset-card h4 {
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .asset-card p {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.7);
        }

        /* Login form (tetap sama) */
        .login-form {
            padding: 48px 42px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 22px;
        }

        .form-title {
            font-size: 26px;
            font-weight: 700;
            color: var(--slate-900);
        }

        .form-subtitle {
            font-size: 14px;
            color: var(--slate-700);
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .field-error {
            color: #b91c1c;
            font-size: 12px;
        }

        .alert {
            padding: 12px 14px;
            border-radius: 12px;
            font-size: 13px;
            border: 1px solid;
        }

        .alert.success {
            background: #ecfeff;
            border-color: #67e8f9;
            color: #0e7490;
        }

        .alert.error {
            background: #fef2f2;
            border-color: #fca5a5;
            color: #b91c1c;
        }

        label {
            font-size: 13px;
            font-weight: 600;
            color: var(--slate-700);
        }

        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 14px 16px;
            border-radius: 12px;
            border: 1px solid #d1d9e6;
            background: var(--white);
            font-size: 14px;
            transition: border 0.2s ease, box-shadow 0.2s ease;
        }

        input[type="email"]:focus,
        input[type="password"]:focus {
            outline: none;
            border-color: var(--purple-500);
            box-shadow: 0 0 0 4px rgba(108, 63, 245, 0.1);
        }

        .form-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 13px;
            color: var(--slate-700);
        }

        .checkbox {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .checkbox input {
            accent-color: var(--purple-500);
        }

        .link {
            color: var(--purple-500);
            text-decoration: none;
            font-weight: 600;
        }

        .link:hover {
            text-decoration: underline;
        }

        .btn-login {
            padding: 14px 16px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(90deg, var(--purple-500), var(--purple-600));
            color: var(--white);
            font-weight: 600;
            font-size: 15px;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            box-shadow: 0 12px 30px rgba(108, 63, 245, 0.35);
        }

        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 36px rgba(108, 63, 245, 0.4);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .secure-note {
            font-size: 12px;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .secure-note svg {
            stroke: var(--purple-500);
        }

        .divider {
            height: 1px;
            width: 100%;
            background: #e2e8f0;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-12px); }
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 900px) {
            .login-card {
                grid-template-columns: 1fr;
            }

            .login-visual {
                display: none;
            }

            .login-form {
                padding: 36px 28px;
            }
        }

        @media (max-width: 520px) {
            .form-row {
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }

            .asset-stack {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
