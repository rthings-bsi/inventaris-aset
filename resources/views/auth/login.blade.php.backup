    <script>
        // State management
        let mouseX = 0, mouseY = 0;
        let isTyping = false;
        let isPurpleBlinking = false;
        let isBlackBlinking = false;
        let isLookingAtEachOther = false;
        let isPurplePeeking = false;

        // Get elements
        const purpleChar = document.getElementById('purpleChar');
        const blackChar = document.getElementById('blackChar');
        const orangeChar = document.getElementById('orangeChar');
        const yellowChar = document.getElementById('yellowChar');

        const purplePupils = [
            document.getElementById('purplePupilLeft'),
            document.getElementById('purplePupilRight')
        ];
        const blackPupils = [
            document.getElementById('blackPupilLeft'),
            document.getElementById('blackPupilRight')
        ];
        const orangePupils = [
            document.getElementById('orangePupilLeft'),
            document.getElementById('orangePupilRight')
        ];
        const yellowPupils = [
            document.getElementById('yellowPupilLeft'),
            document.getElementById('yellowPupilRight')
        ];

        const purpleEyes = [
            document.getElementById('purpleEyeLeft'),
            document.getElementById('purpleEyeRight')
        ];
        const blackEyes = [
            document.getElementById('blackEyeLeft'),
            document.getElementById('blackEyeRight')
        ];

        const emailInput = document.getElementById('email');
        const passwordInput = document.getElementById('password');
        const loginForm = document.getElementById('loginForm');

        // Track mouse movement
        document.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
        });

        // Track typing state
        emailInput.addEventListener('focus', () => {
            isTyping = true;
            purpleChar.classList.add('typing');
            triggerLookAtEachOther();
        });

        emailInput.addEventListener('blur', () => {
            isTyping = false;
            purpleChar.classList.remove('typing');
        });

        passwordInput.addEventListener('focus', () => {
            isTyping = true;
            purpleChar.classList.add('typing');
            triggerLookAtEachOther();
        });

        passwordInput.addEventListener('blur', () => {
            isTyping = false;
            purpleChar.classList.remove('typing');
        });

        // Track password input for peeking animation
        passwordInput.addEventListener('input', () => {
            if (passwordInput.value.length > 0 && !isPurplePeeking) {
                // Random peeking
                setTimeout(() => {
                    if (passwordInput.value.length > 0) {
                        isPurplePeeking = true;
                        purpleChar.classList.add('peeking');

                        setTimeout(() => {
                            purpleChar.classList.remove('peeking');
                            isPurplePeeking = false;
                        }, 800);
                    }
                }, Math.random() * 3000 + 2000);
            }
        });

        // Blinking intervals
        function startBlinking() {
            // Purple character blinking
            setInterval(() => {
                if (!isPurpleBlinking) {
                    isPurpleBlinking = true;
                    purpleEyes.forEach(eye => eye.classList.add('blinking'));

                    setTimeout(() => {
                        purpleEyes.forEach(eye => eye.classList.remove('blinking'));
                        isPurpleBlinking = false;
                    }, 150);
                }
            }, Math.random() * 4000 + 3000);

            // Black character blinking
            setInterval(() => {
                if (!isBlackBlinking) {
                    isBlackBlinking = true;
                    blackEyes.forEach(eye => eye.classList.add('blinking'));

                    setTimeout(() => {
                        blackEyes.forEach(eye => eye.classList.remove('blinking'));
                        isBlackBlinking = false;
                    }, 150);
                }
            }, Math.random() * 4000 + 3000);
        }

        // Trigger look at each other animation
        function triggerLookAtEachOther() {
            isLookingAtEachOther = true;
            blackChar.classList.add('looking');

            setTimeout(() => {
                isLookingAtEachOther = false;
                blackChar.classList.remove('looking');
            }, 800);
        }

        // Calculate pupil position
        function calculatePupilPosition(element, maxDistance = 5) {
            if (!element) return { x: 0, y: 0 };

            const rect = element.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;

            const deltaX = mouseX - centerX;
            const deltaY = mouseY - centerY;
            const distance = Math.min(Math.sqrt(deltaX * deltaX + deltaY * deltaY), maxDistance);

            const angle = Math.atan2(deltaY, deltaX);
            return {
                x: Math.cos(angle) * distance,
                y: Math.sin(angle) * distance
            };
        }

        // Animation loop
        function animate() {
            // Update purple pupils
            purplePupils.forEach(pupil => {
                if (pupil) {
                    const pos = calculatePupilPosition(pupil.parentElement, 8);
                    pupil.style.transform = `translate(${pos.x}px, ${pos.y}px)`;
                }
            });

            // Update black pupils
            blackPupils.forEach(pupil => {
                if (pupil) {
                    const pos = calculatePupilPosition(pupil.parentElement, 6);
                    pupil.style.transform = `translate(${pos.x}px, ${pos.y}px)`;
                }
            });

            // Update orange pupils
            orangePupils.forEach(pupil => {
                if (pupil) {
                    const pos = calculatePupilPosition(pupil.parentElement, 7);
                    pupil.style.transform = `translate(${pos.x}px, ${pos.y}px)`;
                }
            });

            // Update yellow pupils
            yellowPupils.forEach(pupil => {
                if (pupil) {
                    const pos = calculatePupilPosition(pupil.parentElement, 7);
                    pupil.style.transform = `translate(${pos.x}px, ${pos.y}px)`;
                }
            });

            // Update character positions based on mouse
            if (!isLookingAtEachOther) {
                const purpleRect = purpleChar.getBoundingClientRect();
                const blackRect = blackChar.getBoundingClientRect();
                const orangeRect = orangeChar.getBoundingClientRect();
                const yellowRect = yellowChar.getBoundingClientRect();

                const purpleDelta = (mouseX - (purpleRect.left + purpleRect.width/2)) / 30;
                const blackDelta = (mouseX - (blackRect.left + blackRect.width/2)) / 30;
                const orangeDelta = (mouseX - (orangeRect.left + orangeRect.width/2)) / 30;
                const yellowDelta = (mouseX - (yellowRect.left + yellowRect.width/2)) / 30;

                purpleChar.style.transform = `skewX(${Math.max(-6, Math.min(6, purpleDelta))}deg)`;
                blackChar.style.transform = `skewX(${Math.max(-6, Math.min(6, blackDelta))}deg)`;
                orangeChar.style.transform = `skewX(${Math.max(-6, Math.min(6, orangeDelta))}deg)`;
                yellowChar.style.transform = `skewX(${Math.max(-6, Math.min(6, yellowDelta))}deg)`;
            }

            requestAnimationFrame(animate);
        }

        // Start animations
        startBlinking();
        animate();

        // Form submission (tetap menggunakan Laravel, hanya untuk animasi)
        // Tidak mengubah fungsi login asli
    </script>
</body>
</html>